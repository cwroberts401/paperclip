---
import Layout from "../layouts/Layout.astro";
import SceneCanvas from "../components/SceneCanvas.astro";
import ComparisonChart from "../components/ComparisonChart.astro";
import Testimonials from "../components/Testimonials.svelte";
import ProductConfig from "../components/ProductConfig.tsx";
import FactsSection from "../components/FactsSection.astro";
import Footer from "../components/Footer.astro";

const uses = [
    { icon: "📱", label: "SIM ejector" },
    { icon: "🔓", label: "Lock pick (emergency)" },
    { icon: "🔖", label: "Bookmark" },
    { icon: "🔄", label: "Reset button poker" },
    { icon: "🎨", label: "Mini sculpture" },
    { icon: "💡", label: "Circuit tester" },
];

const specs = [
    { label: "Material", value: "Grade 304 Stainless Steel" },
    { label: "Finish", value: "Bright Polished / Matte" },
    { label: "Gauge", value: "0.8mm wire" },
    { label: "Capacity", value: "~50 sheets (80gsm)" },
    { label: "Weight", value: "1.2g per unit" },
    { label: "Dimensions", value: "33mm × 8mm" },
];

// Paper sheets for red → white transition
function seededRandom(seed: number) {
    let s = seed;
    return () => {
        s = (s * 16807 + 0) % 2147483647;
        return (s - 1) / 2147483646;
    };
}

const SHEET_COUNT = 22;
const rand = seededRandom(42);
const sheets = Array.from({ length: SHEET_COUNT }, (_, i) => {
    const angle = rand() * Math.PI * 2;
    const dist = 120 + rand() * 80;
    const startX = Math.cos(angle) * dist;
    const startY = Math.sin(angle) * dist;
    const endX = (rand() - 0.5) * 30;
    const endY = (rand() - 0.5) * 30;
    const rotation = (rand() - 0.5) * 25;
    const delay = (i / SHEET_COUNT) * 0.6;
    const lightness = 96 + rand() * 4;
    const warmth = Math.round(rand() * 10);
    return { startX, startY, endX, endY, rotation, delay, lightness, warmth };
});
---

<Layout>
    <!-- Fixed bottom product bar -->
    <div
        id="product-bar"
        class="w-full max-w-full fixed bottom-0 left-0 right-0 z-30 px-6 pb-6 pt-4 translate-y-full transition-transform duration-500 pointer-events-auto flex justify-center"
    >
        <ProductConfig client:load />
    </div>

    <!-- Red hero overlay -->
    <div
        id="hero-overlay"
        class="fixed inset-0 z-0 flex items-center justify-center pointer-events-none"
    >
        <div class="text-center">
            <h3
                class="text-white font-heading text-xs tracking-[0.3em] uppercase mb-4"
            >
                ACME SUPPLY CO.
            </h3>
            <h1
                id="hero-title"
                class="hero-title leading-[0.85] text-white font-black uppercase"
            >
                <span class="block">Paper</span>
                <span class="block">Clips</span>
            </h1>
        </div>
    </div>

    <!-- Paper sheets: red → white bg transition -->
    <div
        id="paper-transition"
        class="fixed inset-0 z-0 pointer-events-none overflow-hidden"
    >
        {
            sheets.map((s) => (
                <div
                    class="paper-sheet absolute"
                    data-sx={s.startX}
                    data-sy={s.startY}
                    data-ex={s.endX}
                    data-ey={s.endY}
                    data-rot={s.rotation}
                    data-delay={s.delay}
                    style={`
                    width: 140%; height: 140%; top: -20%; left: -20%;
                    background: hsl(40, ${s.warmth}%, ${s.lightness}%);
                    box-shadow: 0 1px 8px rgba(0,0,0,0.08);
                    transform: translate(${s.startX}vw, ${s.startY}vh) rotate(${s.rotation}deg);
                `}
                />
            ))
        }
    </div>

    <!--
      SCROLL-SPACER: canvas is sticky inside here.
      Overlay content scrolls on top while canvas stays pinned.
      Once spacer ends, canvas scrolls away as a static pile image.
    -->
    <div id="scroll-spacer">
        <SceneCanvas />

        <section
            class="scroll-section min-h-[300vh] flex items-center justify-center px-6"
        >
            <ul
                class="text-2xl text-black font-black uppercase list-none space-y-2 text-center"
            >
                <li class="reveal-text mb-4">It's a clip.</li>
                <li class="reveal-text mb-4">It's a chain.</li>
                <li class="reveal-text mb-4">It's a SIM ejector.</li>
                <li class="reveal-text mb-4">It's a bookmark.</li>
                <li class="reveal-text mb-4">It's a lock pick.</li>
                <li class="reveal-text mb-4">It's a reset button poker.</li>
                <li class="reveal-text mb-4">It's a zipper pull.</li>
                <li class="reveal-text mb-4">It's a paperclip.</li>
            </ul>
        </section>

        <!-- Camera pulls back, clip falls into pile -->
        <section class="scroll-section min-h-[200vh]"></section>
    </div>

    <!-- NORMAL PRODUCT PAGE below — canvas stays pinned at top -->
    <div id="page-content" class="relative z-10">
        <!-- Transparent spacer so canvas is visible at top -->
        <div id="canvas-peek" class="h-[50vh]"></div>
        <div class="bg-bg">
            <FactsSection />

            <section class="py-20 px-6">
                <div class="reveal-text">
                    <ComparisonChart />
                </div>
            </section>

            <section class="py-20 px-6">
                <div class="max-w-sm mx-auto w-full">
                    <div class="text-center mb-10 reveal-text">
                        <h2 class="font-impact text-2xl font-bold mb-2">
                            Specs
                        </h2>
                    </div>
                    {
                        specs.map((spec) => (
                            <div class="reveal-text flex justify-between items-baseline py-4 border-b border-black/10">
                                <span class="text-xs text-text-secondary uppercase tracking-wider font-medium">
                                    {spec.label}
                                </span>
                                <span class="text-sm font-heading font-semibold text-right">
                                    {spec.value}
                                </span>
                            </div>
                        ))
                    }
                </div>
            </section>

            <section class="py-20">
                <div class="w-full reveal-text">
                    <Testimonials client:visible />
                </div>
            </section>
        </div>
    </div>
    <Footer />

    <script>
        const bar = document.getElementById("product-bar");
        const overlay = document.getElementById("hero-overlay");
        const sceneWrap = document.getElementById("scene-wrap");
        const canvasPeek = document.getElementById("canvas-peek");
        const paperContainer = document.getElementById("paper-transition");
        const paperSheets =
            document.querySelectorAll<HTMLElement>(".paper-sheet");
        const footer = document.querySelector("footer");
        const body = document.body;

        body.style.background = "#dc2626";

        function clamp01(v: number) {
            return Math.max(0, Math.min(1, v));
        }
        function easeOutCubic(t: number) {
            return 1 - Math.pow(1 - t, 3);
        }
        function lerp(a: number, b: number, t: number) {
            return a + (b - a) * t;
        }

        function onScroll() {
            const scrollY = window.scrollY;
            const vh = window.innerHeight;
            const spacer = document.getElementById("scroll-spacer");
            const spacerBottom = spacer
                ? spacer.offsetTop + spacer.offsetHeight
                : 0;

            // Product bar: show earlier (half a viewport before spacer ends),
            // but hide when footer is visible
            if (bar) {
                const show = scrollY + vh > spacerBottom - vh * 0.5;
                const footerVisible = footer
                    ? footer.getBoundingClientRect().top < vh
                    : false;
                const visible = show && !footerVisible;
                bar.classList.toggle("translate-y-full", !visible);
                bar.classList.toggle("translate-y-0", visible);
            }

            // Hero overlay: fade out
            if (overlay) {
                const fadeT = clamp01(scrollY / (vh * 0.4));
                overlay.style.opacity = String(1 - fadeT);
                overlay.style.display = fadeT >= 1 ? "none" : "";
                const title = document.getElementById("hero-title");
                if (title) {
                    title.style.transform = `scale(${1 + fadeT * 0.3})`;
                    title.style.opacity = String(clamp01(1 - fadeT * 2));
                }
            }

            // Paper sheets: fly in
            const sheetProgress = clamp01(scrollY / (vh * 0.8));
            paperSheets.forEach((el) => {
                const sx = parseFloat(el.dataset.sx!);
                const sy = parseFloat(el.dataset.sy!);
                const ex = parseFloat(el.dataset.ex!);
                const ey = parseFloat(el.dataset.ey!);
                const rot = parseFloat(el.dataset.rot!);
                const delay = parseFloat(el.dataset.delay!);
                const t = easeOutCubic(
                    clamp01((sheetProgress - delay) / (1 - delay)),
                );
                el.style.transform = `translate(${lerp(sx, ex, t)}vw, ${lerp(sy, ey, t)}vh) rotate(${lerp(rot + 15, rot, t)}deg)`;
            });

            if (sheetProgress >= 1) {
                if (paperContainer) paperContainer.style.display = "none";
                body.style.background = "#fafaf9";
            } else {
                if (paperContainer) paperContainer.style.display = "";
                body.style.background = "#dc2626";
            }

            // Hide canvas once user scrolls past the peek window
            if (sceneWrap && canvasPeek) {
                const peekBottom = canvasPeek.getBoundingClientRect().bottom;
                if (peekBottom <= 0) {
                    sceneWrap.style.opacity = "0";
                    sceneWrap.style.pointerEvents = "none";
                } else {
                    sceneWrap.style.opacity = "1";
                }
            }
        }

        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
    </script>
</Layout>
