---
---

<div id="scene-wrap">
  <canvas id="scene-canvas"></canvas>
</div>

<style>
  #scene-wrap {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    z-index: 1;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }
  #scene-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>

<script>
  import { initScene } from './scene';
  import { initScrollManager } from './scroll-manager';
  import type { SceneAPI } from './scene';

  declare global {
    interface Window {
      __sceneAPI?: SceneAPI;
    }
  }

  const canvas = document.getElementById('scene-canvas') as HTMLCanvasElement;
  const sceneAPI = initScene(canvas);
  window.__sceneAPI = sceneAPI;

  // Idle render loop — keeps the clip spinning before any scroll happens.
  // Once the user scrolls, ScrollTrigger takes over rendering.
  let idleRaf = 0;
  let hasScrolled = false;

  function idleLoop() {
    if (!hasScrolled) {
      sceneAPI.render();
      idleRaf = requestAnimationFrame(idleLoop);
    }
  }
  idleRaf = requestAnimationFrame(idleLoop);

  function onFirstScroll() {
    if (!hasScrolled && window.scrollY > 0) {
      hasScrolled = true;
      cancelAnimationFrame(idleRaf);
      window.removeEventListener('scroll', onFirstScroll);
    }
  }
  window.addEventListener('scroll', onFirstScroll, { passive: true });

  const scrollManager = initScrollManager(sceneAPI);

  // Cleanup on page navigation (Astro view transitions)
  document.addEventListener('astro:before-swap', () => {
    hasScrolled = true;
    cancelAnimationFrame(idleRaf);
    scrollManager.destroy();
    sceneAPI.dispose();
    window.__sceneAPI = undefined;
  });
</script>
